# Copy this file to .env and fill in your Supabase project values.
# Get these from: https://supabase.com/dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co

# IMPORTANT: BASE URL only — do NOT add /rest/v1/ at the end
# WRONG: https://xxx.supabase.co/rest/v1/
# RIGHT: https://xxx.supabase.co

# IMPORTANT: Use the LEGACY anon key (starts with eyJ...), NOT sb_publishable_
# In Supabase: Settings → API Keys → Legacy API Keys → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
